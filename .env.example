# VIVARIUM environment — copy to .env (never commit .env). All optional: the
# game runs fully without any of these (scripted narrator + localStorage).

# --- Agent layer (live MXF narrator, Phase 8) -------------------------------
# Server-side only. The key NEVER ships to the client; the browser calls the
# Hono /api/narrate endpoint, which holds the key.
ANTHROPIC_API_KEY=
# Override the narrator model (default: claude-opus-4-8). For a cheap public
# build, route to a faster/cheaper model, e.g. claude-haiku-4-5.
NARRATOR_MODEL=claude-sonnet-4-6

# Opt the CLIENT into live generation (default off → pure scripted, no network).
# Vite-exposed (VITE_ prefix). Set to 1 when YOU are playing / private build.
VITE_LIVE_NARRATOR=1

# --- Persistence (Phase 9) --------------------------------------------------
# Mongo connection. Defaults to localhost; falls back to localStorage if absent.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=vivarium

# --- Server ----------------------------------------------------------------
PORT=8787
