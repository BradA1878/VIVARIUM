{
  "name": "vivarium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VIVARIUM — a 3D Mars-colony survival sim narrated by a colony AI. An Easter egg for bradanderson.org.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "server": "tsx watch server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@hono/node-server": "^2.0.4",
    "@tensorflow/tfjs": "^4.22.0",
    "hono": "^4.12.23",
    "mongodb": "^7.2.0",
    "three": "^0.169.0",
    "vue": "^3.5.12"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
